# Optional tuning (these override bridge.json values when set)
# FEISHU_THINKING_THRESHOLD_MS=2500
# FEISHU_BRIDGE_DEBUG=1

# Media directories
# FEISHU_BRIDGE_ALLOWED_LOCAL_MEDIA_DIRS=~/.codes/media
# FEISHU_BRIDGE_ALLOWED_OUTBOUND_MEDIA_DIRS=~/.codes/media,/tmp

# File size limits
# FEISHU_BRIDGE_MAX_LOCAL_FILE_MB=15
# FEISHU_BRIDGE_MAX_INBOUND_IMAGE_MB=12
# FEISHU_BRIDGE_MAX_INBOUND_FILE_MB=40
